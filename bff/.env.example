# 通义千问 DashScope API Key（仅做饭记 BFF；与 cycle_advisor 的 MINIMAX_API_KEY 不同）
DASHSCOPE_API_KEY=sk-your-dashscope-key-here

# 做饭记 BFF 专用：客户端 RecipeSecrets.appToken、请求头 X-App-Token（不是模型 Key）
APP_TOKEN=openssl-rand-hex-32-here

# 监听地址（可选，默认 :8080）
# 与 nginx-api.smallbeebee.com.snippet 反代到 127.0.0.1:8082 时一致，填：
# LISTEN_ADDR=:8082
LISTEN_ADDR=:8080
